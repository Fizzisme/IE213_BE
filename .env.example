# ==============================
# CẤU HÌNH CƠ SỞ DỮ LIỆU
# ==============================
# Chuỗi kết nối tới MongoDB (ví dụ: mongodb+srv://...)
MONGODB_URI=

# Tên database sử dụng
DATABASE_NAME=EHR


# ==============================
# CẤU HÌNH SERVER
# ==============================
# Địa chỉ host chạy server
APP_HOST=localhost

# Port chạy server
APP_PORT=8080


# ==============================
# CẤU HÌNH XÁC THỰC (JWT)
# ==============================
# Secret key dùng để ký access token
ACCESS_TOKEN_SECRET_SIGNATURE=

# Thời gian sống của access token (ví dụ: 9h, 15m, 7d)
ACCESS_TOKEN_LIFE=9h

# Secret key dùng để ký refresh token
REFRESH_TOKEN_SECRET_SIGNATURE=

# Thời gian sống của refresh token
REFRESH_TOKEN_LIFE=9h


# ==============================
# CẤU HÌNH BLOCKCHAIN (SEPOLIA)
# ==============================
# URL RPC để kết nối tới blockchain (Infura, Alchemy, ...)
BLOCKCHAIN_RPC_URL=

# Private key của admin (chỉ dùng cho môi trường dev/test)
# KHÔNG được commit lên Git
ADMIN_PRIVATE_KEY=


# ==============================
# VÍ TEST (CHỈ DÙNG CHO DEV)
# ==============================
# Private key ví bệnh nhân test
TEST_PATIENT_PRIVATE_KEY=

# Private key ví bác sĩ test
TEST_DOCTOR_PRIVATE_KEY=

# Private key ví phòng lab test
TEST_LAB_PRIVATE_KEY=


# ==============================
# ĐỊA CHỈ SMART CONTRACT
# ==============================
# Địa chỉ contract quản lý danh tính
IDENTITY_MANAGER_ADDRESS=

# Địa chỉ contract phân quyền truy cập
DYNAMIC_ACCESS_CONTROL_ADDRESS=

# Địa chỉ contract lưu trữ dữ liệu y tế
MEDICAL_LEDGER_ADDRESS=


# ==============================
# CẤU HÌNH HỆ THỐNG
# ==============================
# Địa chỉ ví admin đầu tiên của hệ thống
INITIAL_ADMIN_WALLET_ADDRESS=


# ==============================
# DỊCH VỤ BÊN NGOÀI
# ==============================
# API key của Etherscan để verify contract hoặc đọc dữ liệu
ETHERSCAN_API_KEY=

# RPC dự phòng (backup) cho mạng Sepolia
SEPOLIA_RPC_URL=
