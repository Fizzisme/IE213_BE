# ==============================
# MongoDB
# ==============================
MONGODB_URI='mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=<app-name>'
DATABASE_NAME='EHR'
APP_HOST='localhost'
APP_PORT=8017

# ==============================
# JWT
# ==============================
ACCESS_TOKEN_SECRET_SIGNATURE='CHANGE_ME_ACCESS_SECRET'
ACCESS_TOKEN_LIFE='20m'

REFRESH_TOKEN_SECRET_SIGNATURE='CHANGE_ME_REFRESH_SECRET'
REFRESH_TOKEN_LIFE='14 days'

# ==============================
# Blockchain (Sepolia)
# ==============================
SEPOLIA_RPC_URL='https://eth-sepolia.g.alchemy.com/v2/<your-alchemy-key>'
ADMIN_PRIVATE_KEY='<your-admin-wallet-private-key>'
CHAIN_ID=11155111

ACCOUNT_MANAGER_ADDRESS='0xYourAccountManagerAddress'
ACCESS_CONTROL_ADDRESS='0xYourAccessControlAddress'
EHR_MANAGER_ADDRESS='0xYourEHRManagerAddress'

# Notes:
# 1) Never commit .env with real secrets.
# 2) Copy this file to .env and fill real values.
# 3) Use a test wallet only (Sepolia), not a wallet with real funds.
