                    }
                },
                {
                    "name": "Step 5: Doctor Completes (COMPLETE)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{ACCESS_TOKEN}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"labOrderId\": \"{{LAB_ORDER_ID}}\"\n}"
                        },
                        "url": {
                            "raw": "{{BASE_URL}}{{API_VERSION}}/ehr-workflow/complete\",\n              \"host\": [\n                \"{{BASE_URL}}\"\n              ],\n              \"path\": [\n                \"{{API_VERSION}}\",\n                \"ehr-workflow\",\n                \"complete\"\n              ]\n            }\n          }\n        }\n      ]\n    },\n    {\n      \"name\": \"🔐 Access Control\",\n      \"item\": [\n        {\n          \"name\": \"Grant Access to Doctor\",\n          \"request\": {\n            \"method\": \"POST\",\n            \"header\": [\n              {\n                \"key\": \"Authorization\",\n                \"value\": \"Bearer {{ACCESS_TOKEN}}\"\n              },\n              {\n                \"key\": \"Content-Type\",\n                \"value\": \"application/json\"\n              }\n            ],\n            \"body\": {\n              \"mode\": \"raw\",\n              \"raw\": \"{\\n  \\\"accessor\\\": \\\"{{DOCTOR_WALLET_ADDRESS}}\\\",\\n  \\\"level\\\": \\\"FULL\\\",\\n  \\\"durationHours\\\": 24\\n}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}{{API_VERSION}}/access-control/grant\",\n              \"host\": [\n                \"{{BASE_URL}}\"\n              ],\n              \"path\": [\n                \"{{API_VERSION}}\",\n                \"access-control\",\n                \"grant\"\n              ]\n            }\n          }\n        },\n        {\n          \"name\": \"Revoke Access\",\n          \"request\": {\n            \"method\": \"DELETE\",\n            \"header\": [\n              {\n                \"key\": \"Authorization\",\n                \"value\": \"Bearer {{ACCESS_TOKEN}}\"\n              },\n              {\n                \"key\": \"Content-Type\",\n                \"value\": \"application/json\"\n              }\n            ],\n            \"body\": {\n              \"mode\": \"raw\",\n              \"raw\": \"{\\n  \\\"accessor\\\": \\\"{{DOCTOR_WALLET_ADDRESS}}\\\"\\n}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}{{API_VERSION}}/access-control/revoke\",\n              \"host\": [\n                \"{{BASE_URL}}\"\n              ],\n              \"path\": [\n                \"{{API_VERSION}}\",\n                \"access-control\",\n                \"revoke\"\n              ]\n            }\n          }\n        }\n      ]\n    },\n    {\n      \"name\": \"🏥 Blockchain\",\n      \"item\": [\n        {\n          \"name\": \"Check Blockchain Health\",\n          \"request\": {\n            \"method\": \"GET\",\n            \"header\": [],\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}{{API_VERSION}}/blockchain/health\",\n              \"host\": [\n                \"{{BASE_URL}}\"\n              ],\n              \"path\": [\n                \"{{API_VERSION}}\",\n                \"blockchain\",\n                \"health\"\n              ]\n            }\n          }\n        }\n      ]\n    }\n  ]\n}\n