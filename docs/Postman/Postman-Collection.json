                                "key": "Authorization",
                                "value": "Bearer {{ACCESS_TOKEN}}"
                            }
                        ],
                        "url": {
                            "raw": "{{BASE_URL}}{{API_VERSION}}/patients",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "{{API_VERSION}}",
                                "patients"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "📋 Lab Order",
            "item": [
                {
                    "name": "Create Lab Order (ORDERED)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{ACCESS_TOKEN}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"patientAddress\": \"{{PATIENT_WALLET_ADDRESS}}\",\n  \"recordType\": \"{{RECORD_TYPE}}\",\n  \"testsRequested\": [\n    {\n      \"code\": \"GLUCOSE\",\n      \"name\": \"Glucose Test\",\n      \"note\": \"Fasting glucose measurement\"\n    }\n  ],\n  \"priority\": \"normal\",\n  \"clinicalNote\": \"{{CLINICAL_NOTE}}\",\n  \"sampleType\": \"{{SAMPLE_TYPE}}\",\n  \"diagnosisCode\": \"{{DIAGNOSIS_CODE}}\",\n  \"diagnosisName\": \"{{DIAGNOSIS_NAME}}\",\n  \"patientId\": \"{{PATIENT_ID}}\",\n  \"patientName\": \"{{PATIENT_NAME}}\",\n  \"patientDOB\": \"{{PATIENT_DOB}}\"\n}"
                        },
                        "url": {
                            "raw": "{{BASE_URL}}{{API_VERSION}}/lab-orders",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "{{API_VERSION}}",
                                "lab-orders"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 201) {",
                                    "    var data = pm.response.json();",
                                    "    pm.environment.set('LAB_ORDER_ID', data.labOrderId);",
                                    "    pm.environment.set('BLOCKCHAIN_RECORD_ID', data.recordId);",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Get Lab Order Details",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{ACCESS_TOKEN}}"
                            }
                        ],
                        "url": {
                            "raw": "{{BASE_URL}}{{API_VERSION}}/lab-orders/{{LAB_ORDER_ID}}",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "{{API_VERSION}}",
                                "lab-orders",
                                "{{LAB_ORDER_ID}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Lab Orders List",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{ACCESS_TOKEN}}"
                            }
                        ],
                        "url": {
                            "raw": "{{BASE_URL}}{{API_VERSION}}/lab-orders?page=1&limit=10",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "{{API_VERSION}}",
                                "lab-orders"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "10"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "🔄 Workflow",
            "item": [
                {
                    "name": "Step 1: Patient Consents (CONSENTED)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{ACCESS_TOKEN}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"labOrderId\": \"{{LAB_ORDER_ID}}\"\n}"
                        },
                        "url": {
                            "raw": "{{BASE_URL}}{{API_VERSION}}/ehr-workflow/consent",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "{{API_VERSION}}",
                                "ehr-workflow",
                                "consent"
                            ]
                        }
                    }
                },
                {
                    "name": "Step 2: Lab Tech Receives (IN_PROGRESS)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{ACCESS_TOKEN}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"labOrderId\": \"{{LAB_ORDER_ID}}\"\n}"
                        },
                        "url": {
                            "raw": "{{BASE_URL}}{{API_VERSION}}/ehr-workflow/receive-order",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "{{API_VERSION}}",
                                "ehr-workflow",
                                "receive-order"
                            ]
                        }
                    }
                },
                {
                    "name": "Step 3: Lab Tech Posts Result (RESULT_POSTED)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{ACCESS_TOKEN}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"labOrderId\": \"{{LAB_ORDER_ID}}\",\n  \"resultData\": {\n    \"rawData\": {\n      \"glucose\": 95,\n      \"unit\": \"mg/dL\",\n      \"normalRange\": \"70-100\"\n    },\n    \"note\": \"{{LAB_RESULT_NOTE}}\"\n  }\n}"
                        },
                        "url": {
                            "raw": "{{BASE_URL}}{{API_VERSION}}/ehr-workflow/post-result",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "{{API_VERSION}}",
                                "ehr-workflow",
                                "post-result"
                            ]
                        }
                    }
