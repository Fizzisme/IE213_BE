        {
            "name": "👤 Patient",
            "item": [
                {
                    "name": "Create Patient Profile",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{ACCESS_TOKEN}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"fullName\": \"{{PATIENT_NAME}}\",\n  \"dateOfBirth\": \"{{PATIENT_DOB}}\",\n  \"gender\": \"MALE\",\n  \"phone\": \"{{PATIENT_PHONE}}\",\n  \"address\": \"{{PATIENT_ADDRESS}}\",\n  \"medicalHistory\": \"No known allergies\"\n}"
                        },
                        "url": {
                            "raw": "{{BASE_URL}}{{API_VERSION}}/patients",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "{{API_VERSION}}",
                                "patients"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 201) {",
                                    "    var data = pm.response.json();",
                                    "    pm.environment.set('PATIENT_ID', data.patientId || data._id);",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Get Patient Details",
                    "request": {
                        "method": "GET",
                        "header": [
