{
    "info": {
        "name": "EHR Project - API Collection",
        "description": "Comprehensive API collection for EHR project testing",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "🔐 Authentication",
            "item": [
                {
                    "name": "Register Patient",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"{{TEST_EMAIL}}\",\n  \"password\": \"{{TEST_PASSWORD}}\",\n  \"nationId\": \"{{PATIENT_NATION_ID}}\"\n}"
                        },
                        "url": {
                            "raw": "{{BASE_URL}}{{API_VERSION}}/auth/register",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "{{API_VERSION}}",
                                "auth",
                                "register"
                            ]
                        }
                    }
                },
                {
                    "name": "Login by NationId",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"nationId\": \"{{PATIENT_NATION_ID}}\",\n  \"password\": \"{{TEST_PASSWORD}}\"\n}"
                        },
                        "url": {
                            "raw": "{{BASE_URL}}{{API_VERSION}}/auth/login/nationId",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "{{API_VERSION}}",
                                "auth",
                                "login",
                                "nationId"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "    var data = pm.response.json();",
                                    "    pm.environment.set('ACCESS_TOKEN', data.accessToken);",
                                    "    pm.environment.set('REFRESH_TOKEN', data.refreshToken);",
                                    "    pm.environment.set('CURRENT_USER_ID', data.user._id);",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Login by Wallet - Phase 1 (Get Nonce)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"walletAddress\": \"{{CURRENT_WALLET_ADDRESS}}\"\n}"
                        },
                        "url": {
                            "raw": "{{BASE_URL}}{{API_VERSION}}/auth/login/wallet",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "{{API_VERSION}}",
                                "auth",
                                "login",
                                "wallet"
                            ]
                        }
                    }
                },
                {
                    "name": "Login by Wallet - Phase 2 (Verify)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"walletAddress\": \"{{CURRENT_WALLET_ADDRESS}}\",\n  \"signature\": \"0x...\"\n}"
                        },
                        "url": {
                            "raw": "{{BASE_URL}}{{API_VERSION}}/auth/login/wallet",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "{{API_VERSION}}",
                                "auth",
                                "login",
                                "wallet"
                            ]
                        }
                    }
                },
