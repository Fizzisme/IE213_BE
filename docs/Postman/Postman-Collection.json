                    "name": "Step 4: Doctor Interprets (DOCTOR_REVIEWED)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{ACCESS_TOKEN}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"labOrderId\": \"{{LAB_ORDER_ID}}\",\n  \"interpretationData\": {\n    \"interpretation\": \"{{CLINICAL_INTERPRETATION}}\",\n    \"recommendation\": \"{{RECOMMENDATION}}\"\n  }\n}"
                        },
                        "url": {
                            "raw": "{{BASE_URL}}{{API_VERSION}}/ehr-workflow/add-interpretation",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "{{API_VERSION}}",
                                "ehr-workflow",
                                "add-interpretation"
                            ]
